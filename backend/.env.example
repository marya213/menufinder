PORT=5001
## Option 1: full URI (works for local or Atlas)
## MONGO_URI=mongodb://127.0.0.1:27017/menufinder

## Option 2: set separate Atlas credentials (the app will build the URI):
## MONGO_USER=yourAtlasUser
## MONGO_PASS=yourAtlasPassword
## MONGO_HOST=cluster0.abcd123.mongodb.net
## MONGO_DB=menufinder
## Example constructed URI: mongodb+srv://<user>:<pass>@cluster0.abcd123.mongodb.net/menufinder?retryWrites=true&w=majority
USE_MOCKS=false
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
